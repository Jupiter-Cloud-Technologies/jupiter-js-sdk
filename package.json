{
  "name": "jupiter-js",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "JavaScript and TypeScript SDKs for Jupiter Cloud.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jupiter-Cloud-Technologies/jupiter-js-sdk"
  },
  "bugs": {
    "url": "https://github.com/Jupiter-Cloud-Technologies/jupiter-js-sdk/issues"
  },
  "homepage": "https://github.com/Jupiter-Cloud-Technologies/jupiter-js-sdk#readme",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "fflate": "0.8.2"
    }
  },
  "scripts": {
    "build": "turbo run build --filter=!jupiter-js",
    "changeset": "changeset",
    "check:versions": "node scripts/sync-versions.mjs --check",
    "check:exports": "turbo run check:exports --filter=!jupiter-js",
    "clean": "turbo run clean --filter=!jupiter-js",
    "docs": "typedoc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint --filter=!jupiter-js",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "release": "pnpm check:versions && changeset publish",
    "smoke:packages": "node scripts/smoke-packages.mjs",
    "sync:versions": "node scripts/sync-versions.mjs",
    "test": "turbo run test --filter=!jupiter-js",
    "test:types": "turbo run test:types --filter=!jupiter-js",
    "typecheck": "turbo run typecheck --filter=!jupiter-js",
    "version-packages": "changeset version && pnpm sync:versions"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "^2.27.12",
    "@eslint/js": "^10.0.1",
    "@types/node": "26.1.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "publint": "^0.3.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.10.4",
    "typedoc": "^0.28.20",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
