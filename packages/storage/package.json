{
  "name": "@jupiter-cloud/storage",
  "version": "0.1.0",
  "description": "JavaScript and TypeScript client for Jupiter Storage.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "check:exports": "attw --pack . && publint",
    "clean": "rm -rf dist coverage",
    "lint": "eslint .",
    "test": "vitest run",
    "test:types": "tsd",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsd": "^0.31.2"
  },
  "dependencies": {
    "@jupiter-cloud/core": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  },
  "tsd": {
    "directory": "test/types"
  }
}
