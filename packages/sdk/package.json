{
  "name": "@jupiter-cloud/sdk",
  "version": "0.5.0",
  "description": "Aggregate JavaScript and TypeScript client for Jupiter Cloud.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jupiter-Cloud-Technologies/jupiter-js-sdk",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Jupiter-Cloud-Technologies/jupiter-js-sdk/issues"
  },
  "homepage": "https://github.com/Jupiter-Cloud-Technologies/jupiter-js-sdk#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "check:exports": "attw --pack . && publint",
    "clean": "rm -rf dist coverage",
    "lint": "eslint .",
    "test": "vitest run",
    "test:types": "tsd",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jupiter-cloud/auth": "workspace:*",
    "@jupiter-cloud/core": "workspace:*",
    "@jupiter-cloud/storage": "workspace:*",
    "@jupiter-cloud/postgrest": "workspace:*"
  },
  "devDependencies": {
    "tsd": "^0.33.0"
  },
  "engines": {
    "node": ">=20"
  },
  "tsd": {
    "directory": "test/types"
  }
}
